# Salin file ini jadi ".env" di folder yang sama, lalu isi nilainya.
# .env TIDAK boleh di-commit ke git / dibagikan (berisi kredensial).

# "supabase" (default, data tersimpan permanen & bisa dibaca dashboard
# dari mana saja) atau "sqlite" (lokal, buat testing cepat tanpa akun).
DB_BACKEND=supabase

# Ambil dari Supabase Dashboard -> Project Settings -> API.
# Pakai "anon public" key untuk mulai; kalau nanti mau lebih ketat soal
# akses tulis, pindah crawler ke "service_role" key dan set RLS read-only
# untuk anon key (dashboard).
SUPABASE_URL=https://pfbsehzykiketfhrqdiw.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBmYnNlaHp5a2lrZXRmaHJxZGl3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQwMDQ0MjAsImV4cCI6MjA5OTU4MDQyMH0.zmeQdTCdiiupwdmUJEm_gPftMxQ90z4w_9IsYd6AHBw

# Cuma dipakai kalau DB_BACKEND=sqlite
DB_PATH=news.db

# Seberapa sering crawler jalan ulang (menit)
CRAWL_INTERVAL_MINUTES=30
